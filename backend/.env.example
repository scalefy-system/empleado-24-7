# =============================================================================
# CONFIGURACIÓN DEL BACKEND - LUMINA ESTÉTICA
# =============================================================================
# Copiar este archivo a .env y completar con tus credenciales
# NO subir este archivo a GitHub - ya está excluido en .gitignore

# -----------------------------------------------------------------------------
# SERVIDOR
# -----------------------------------------------------------------------------

# Puerto del servidor (por defecto: 3001)
PORT=3001

# -----------------------------------------------------------------------------
# OPENAI - CHATBOT
# -----------------------------------------------------------------------------

# API Key de OpenAI (OBLIGATORIO)
# Obtener en: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-tu-api-key-aqui

# Modelo a usar (opcional, por defecto gpt-4o-mini)
# Modelos disponibles: gpt-4o-mini, gpt-4o, gpt-3.5-turbo
OPENAI_MODEL=gpt-4o-mini

# Configuración avanzada del modelo (opcional)
OPENAI_MAX_TOKENS=500
OPENAI_TEMPERATURE=0.7

# -----------------------------------------------------------------------------
# RATE LIMITING (Opcional)
# -----------------------------------------------------------------------------

# Tiempo de ventana para rate limiting en ms (por defecto: 60000 = 1 minuto)
RATE_LIMIT_WINDOW_MS=60000

# Máximo de requests por ventana (por defecto: 20)
RATE_LIMIT_MAX_REQUESTS=20

# -----------------------------------------------------------------------------
# SESIONES DEL CHAT (Opcional)
# -----------------------------------------------------------------------------

# Tiempo de vida de la sesión en minutos (por defecto: 60)
SESSION_TTL_MINUTES=60

# Máximo de mensajes en el historial (por defecto: 20)
MAX_HISTORY_MESSAGES=20
